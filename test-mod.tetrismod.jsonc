        {
            "Name": "Test Mod Palette",
            "Block Colors": {
                "—": "#f4dbd6",
                "[": "#f0c6c6",
                "]": "#f5bde6"
            },
            "UI Theme": "Test Mod Theme"
        }
    ],
    "Override Levels": true, // true: Replace default level pack. false: Append to default level pack.
    /* (Optional Field)
     * --Level Guide--
     * Name              : string : <any>
     * Speed Multiplier  : float  : (0,100)
     * Score Requirement : int    : [0,inf)
     * Points Multiplier : int?   : (0,inf) // Leave absent to use default points multiplier math (levelIndex * points)
