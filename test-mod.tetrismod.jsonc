    "UI Themes": [
        {
            "Name": "Test Mod Theme"
        }
    ],
    /* (Optional Field)
     * --Palette Guide--
     * Name         : string               : <any>
     * Block Colors : Dict<string, string> : {
     *      <Block Symbol> : <CSS string color : HEX, rgb, hsv, etc.>
     *      ...
     * }
     * UI Theme     : string?              : <any>
     */
