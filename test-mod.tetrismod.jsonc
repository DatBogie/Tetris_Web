    /* (Optional Field)
     * --UI Theme Guide--
     * Name  : string               : <any>
     * Style : string?              : "Dark"|"Light"
     * Data  : Dict<string, string> : {
     *      // Omitted colors derive from the default style (Catppuccin Macchiato Lavender)
     *      olc       : string? : HEX, rgb(a), hsv(a), hsl(a) // Outline Color
     *      rosewater : string? : HEX, rgb(a), hsv(a), hsl(a)
     *      flamingo  : string? : HEX, rgb(a), hsv(a), hsl(a)
     *      pink      : string? : HEX, rgb(a), hsv(a), hsl(a)
     *      mauve     : string? : HEX, rgb(a), hsv(a), hsl(a)
     *      red       : string? : HEX, rgb(a), hsv(a), hsl(a)
     *      maroon    : string? : HEX, rgb(a), hsv(a), hsl(a)
     *      peach     : string? : HEX, rgb(a), hsv(a), hsl(a)
     *      yellow    : string? : HEX, rgb(a), hsv(a), hsl(a)
     *      green     : string? : HEX, rgb(a), hsv(a), hsl(a)
     *      teal      : string? : HEX, rgb(a), hsv(a), hsl(a)
     *      sky       : string? : HEX, rgb(a), hsv(a), hsl(a)
     *      sapphire  : string? : HEX, rgb(a), hsv(a), hsl(a)
     *      blue      : string? : HEX, rgb(a), hsv(a), hsl(a)
     *      lavender  : string? : HEX, rgb(a), hsv(a), hsl(a)
