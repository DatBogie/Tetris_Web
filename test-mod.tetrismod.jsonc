     *      overlay2  : string? : HEX, rgb(a), hsv(a), hsl(a)
     *      surface0  : string? : HEX, rgb(a), hsv(a), hsl(a)
     *      surface1  : string? : HEX, rgb(a), hsv(a), hsl(a)
     *      surface2  : string? : HEX, rgb(a), hsv(a), hsl(a)
